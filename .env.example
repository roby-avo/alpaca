# Copy to .env.
# No auth in local dev stack.

# Image versions (pinned as of 2026-03-05 from upstream registries)
ALPACA_POSTGRES_VERSION=18.3
ALPACA_ADMINER_VERSION=5
ALPACA_ELASTIC_VERSION=9.3.1
ALPACA_ELASTICVUE_VERSION=1.13.0

# Ports
ALPACA_POSTGRES_PORT=5432
ALPACA_ADMINER_PORT=8080
ALPACA_API_PORT=8000
ALPACA_ELASTIC_PORT=9200
ALPACA_ELASTICVUE_PORT=8081

# Service CPU/memory caps for a low-power VM profile
ALPACA_POSTGRES_MEM_LIMIT=1g
ALPACA_POSTGRES_CPUS=1.0
ALPACA_ADMINER_MEM_LIMIT=128m
ALPACA_ADMINER_CPUS=0.25
ALPACA_API_MEM_LIMIT=768m
ALPACA_API_CPUS=1.0
ALPACA_ELASTIC_MEM_LIMIT=1g
ALPACA_ELASTIC_CPUS=1.0
ALPACA_ELASTICVUE_MEM_LIMIT=128m
ALPACA_ELASTICVUE_CPUS=0.25

# Postgres (trust auth in docker-compose for local dev)
ALPACA_POSTGRES_DB=alpaca
ALPACA_POSTGRES_USER=postgres
ALPACA_POSTGRES_MAX_CONNECTIONS=200
ALPACA_POSTGRES_DSN=postgresql://postgres@postgres:5432/alpaca
ALPACA_ADMINER_DEFAULT_SERVER=postgres

# Low-footprint Postgres tuning defaults
ALPACA_POSTGRES_SHM_SIZE=1GB
ALPACA_POSTGRES_SHARED_BUFFERS=256MB
ALPACA_POSTGRES_EFFECTIVE_CACHE_SIZE=768MB
ALPACA_POSTGRES_WORK_MEM=2MB
ALPACA_POSTGRES_MAINTENANCE_WORK_MEM=64MB
ALPACA_POSTGRES_RANDOM_PAGE_COST=1.25
ALPACA_POSTGRES_EFFECTIVE_IO_CONCURRENCY=16
ALPACA_POSTGRES_CHECKPOINT_COMPLETION_TARGET=0.9
ALPACA_POSTGRES_MAX_WAL_SIZE=1GB
ALPACA_POSTGRES_WAL_COMPRESSION=on
ALPACA_POSTGRES_MAX_PARALLEL_WORKERS=2
ALPACA_POSTGRES_MAX_PARALLEL_WORKERS_PER_GATHER=1

# Elasticsearch low-footprint defaults
ALPACA_ELASTIC_NODE_NAME=alpaca-es
ALPACA_ELASTIC_CLUSTER_NAME=alpaca
ALPACA_ELASTIC_HEAP_SIZE=1g
# If you need wildcard CORS, set ALPACA_ELASTIC_CORS_ALLOW_ORIGIN=* (compose wraps it safely).
ALPACA_ELASTIC_CORS_ALLOW_ORIGIN=http://localhost:8081
ALPACA_ELASTICSEARCH_URL=http://elasticsearch:9200

# Optional host data paths
# ALPACA_POSTGRES_DATA_DIR=./data/postgres
# ALPACA_ELASTIC_DATA_DIR=./data/elasticsearch
# ALPACA_INPUT_DIR=./data/input
# ALPACA_OUTPUT_DIR=./data/output
