# Copy this file to .env and fill only the values needed for your run.
# Keep .env private; it is intentionally ignored by git.

# Image versions (pinned as of 2026-03-06 from upstream registries)
ALPACA_POSTGRES_VERSION=18.3
ALPACA_ADMINER_VERSION=5
ALPACA_ELASTIC_VERSION=9.3.1
ALPACA_ELASTICVUE_VERSION=1.13.0

# Ports
ALPACA_POSTGRES_PORT=5432
ALPACA_ADMINER_PORT=8080
ALPACA_API_PORT=8000
ALPACA_ELASTIC_PORT=9200
ALPACA_ELASTICVUE_PORT=8080

# Postgres (trust auth in docker-compose for local dev)
ALPACA_POSTGRES_DB=alpaca
ALPACA_POSTGRES_USER=postgres
ALPACA_POSTGRES_MAX_CONNECTIONS=200
ALPACA_POSTGRES_DSN=postgresql://postgres@postgres:5432/alpaca

# Minimal Postgres tuning defaults
ALPACA_POSTGRES_SHM_SIZE=1GB

# Elasticsearch low-footprint defaults
ALPACA_ELASTIC_NODE_NAME=alpaca-es
ALPACA_ELASTIC_CLUSTER_NAME=alpaca
ALPACA_ELASTIC_HEAP_SIZE=1g
# Wildcard CORS default for local tunneling/forwarding (compose wraps it safely).
ALPACA_ELASTIC_CORS_ALLOW_ORIGIN=*
ALPACA_ELASTICSEARCH_URL=http://elasticsearch:9200

# Optional host data paths
# ALPACA_POSTGRES_DATA_DIR=./data/postgres
# ALPACA_ELASTIC_DATA_DIR=./data/elasticsearch
# ALPACA_INPUT_DIR=./data/input
# ALPACA_OUTPUT_DIR=./data/output

# backend_lab read-only backend endpoints.
# These can point to an SSH-forwarded backend, VPN backend, or local compose stack.
ALPACA_API_URL=http://roberto-vm.vpn.sintef:8004
ALPACA_ES_URL=http://roberto-vm.vpn.sintef:9209
# ALPACA_DATASET_ROOT=/absolute/path/to/alpaca/Coverage_exp/Datasets

# backend_lab LLM provider configuration.
# The client uses the OpenAI SDK interface. For DeepInfra, either variable below works.
# ALPACA_LLM_API_KEY=your_provider_key
# DEEPINFRA_TOKEN=your_deepinfra_key
ALPACA_LLM_BASE_URL=https://api.deepinfra.com/v1/openai
ALPACA_LLM_MODEL=openai/gpt-oss-20b
ALPACA_LLM_TEMPERATURE=0

# LLM request stability controls.
ALPACA_LLM_TIMEOUT_SECONDS=90
ALPACA_LLM_TIMEOUT_MULTIPLIER=1.8
ALPACA_LLM_TIMEOUT_MAX_SECONDS=300
ALPACA_LLM_MAX_RETRIES=2
ALPACA_LLM_RETRY_BACKOFF_SECONDS=2
ALPACA_LLM_RETRY_MAX_SLEEP_SECONDS=20

# Optional LLM cache for local inspection or production-style runs.
# Experiments should normally use --cache-mode off for fair comparison.
ALPACA_LLM_CACHE_ENABLED=1
# ALPACA_LLM_CACHE_DIR=./backend_lab/.cache
