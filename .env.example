# Copy to .env and pin versions after verifying on Docker Hub.
# No auth in local dev stack.

# Image versions (pin explicitly here)
ALPACA_POSTGRES_VERSION=18.1
ALPACA_ADMINER_VERSION=5

# Ports
ALPACA_POSTGRES_PORT=5432
ALPACA_ADMINER_PORT=8080
ALPACA_API_PORT=8000

# Postgres (trust auth in docker-compose for local dev)
ALPACA_POSTGRES_DB=alpaca
ALPACA_POSTGRES_USER=postgres
ALPACA_POSTGRES_MAX_CONNECTIONS=200
ALPACA_POSTGRES_DSN=postgresql://postgres@postgres:5432/alpaca
ALPACA_ADMINER_DEFAULT_SERVER=postgres
#
# VM-oriented Postgres tuning defaults for the documented shared 8 vCPU / ~30 GiB VM.
# These are intentionally conservative because the VM runs other services too.
ALPACA_POSTGRES_SHM_SIZE=6gb
ALPACA_POSTGRES_SHARED_BUFFERS=4GB
ALPACA_POSTGRES_EFFECTIVE_CACHE_SIZE=8GB
ALPACA_POSTGRES_WORK_MEM=8MB
ALPACA_POSTGRES_MAINTENANCE_WORK_MEM=1GB
ALPACA_POSTGRES_RANDOM_PAGE_COST=1.25
ALPACA_POSTGRES_EFFECTIVE_IO_CONCURRENCY=32
ALPACA_POSTGRES_CHECKPOINT_COMPLETION_TARGET=0.9
ALPACA_POSTGRES_MAX_WAL_SIZE=4GB
ALPACA_POSTGRES_WAL_COMPRESSION=on
ALPACA_POSTGRES_MAX_PARALLEL_WORKERS=4
ALPACA_POSTGRES_MAX_PARALLEL_WORKERS_PER_GATHER=1

# Optional host data paths
# ALPACA_POSTGRES_DATA_DIR=./data/postgres
# ALPACA_INPUT_DIR=./data/input
# ALPACA_OUTPUT_DIR=./data/output
